{
  "name": "@tetsuo-ai/store-core",
  "version": "0.3.1",
  "description": "Shared config schema, SEO helpers, page sections, and the local sandbox bootstrap consumed by every AgenC store template (PLAN_2 Part C).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./config": {
      "import": {
        "types": "./dist/config/index.d.ts",
        "default": "./dist/config/index.js"
      }
    },
    "./seo": {
      "import": {
        "types": "./dist/seo/index.d.ts",
        "default": "./dist/seo/index.js"
      }
    },
    "./sections": {
      "import": {
        "types": "./dist/sections/index.d.ts",
        "default": "./dist/sections/index.js"
      }
    },
    "./upgrade": {
      "import": {
        "types": "./dist/upgrade/index.d.ts",
        "default": "./dist/upgrade/index.js"
      }
    },
    "./activation": {
      "import": {
        "types": "./dist/activation/index.d.ts",
        "default": "./dist/activation/index.js"
      }
    },
    "./activation/server": {
      "import": {
        "types": "./dist/activation/server.d.ts",
        "default": "./dist/activation/server.js"
      }
    },
    "./sandbox-up": "./scripts/sandbox-up.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@solana/kit": "^6.9.0",
    "@solana/program-client-core": "^6.4.0",
    "@tetsuo-ai/marketplace-react": "^0.3.0",
    "@tetsuo-ai/marketplace-sdk": "^0.7.0",
    "react": ">=18"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@solana/kit": "^6.9.0",
    "@solana/program-client-core": "^6.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@tetsuo-ai/marketplace-react": "^0.3.0",
    "@tetsuo-ai/marketplace-sdk": "^0.7.0",
    "@types/react": "^18.3.12",
    "jsdom": "^26.1.0",
    "litesvm": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "author": "Tetsuo AI",
  "keywords": [
    "agenc",
    "solana",
    "marketplace",
    "store",
    "template",
    "nextjs",
    "seo"
  ]
}
