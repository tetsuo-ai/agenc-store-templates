# marketplace-store — environment overrides
#
# Everything a deployer normally needs lives in agenc.config.ts. These env vars
# are OPTIONAL overrides for hosting (Vercel/Netlify) where you don't want to
# commit secrets or a per-environment endpoint into the config file.

# Override the gPA fallback RPC endpoint (defaults per network: localnet =
# http://127.0.0.1:8899, devnet/mainnet = the public Solana RPC). Set this to
# your own RPC for production reliability.
# AGENC_RPC_URL=

# BROWSER RPC override (NEXT_PUBLIC_ = baked into the client bundle; treat it
# as public). The public mainnet RPC rejects browser JSON-RPC, so a mainnet
# store needs a real endpoint here for catalog reads and hire/activation
# writes. Use a browser-safe key (rate-limited, origin-restricted).
# NEXT_PUBLIC_AGENC_RPC_URL=

# The hosted-indexer API key (X-Agenc-Api-Key). Anonymous reads work without it
# at a lower rate. Mirror this value in agenc.config.ts -> api.apiKey, or read it
# there from process.env.AGENC_API_KEY.
# AGENC_API_KEY=
